@model Shipper
@{
    ViewBag.Title = "Xóa người giao hàng";
}
@section PageToolBar {
    @if (ViewBag.CanDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0 text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @(ViewBag.CanDelete ? "Xác nhận xóa người giao hàng" : "Thông báo")
        </h5>
    </div>
    <div class="card-body">
        <form id="formDelete" method="post" action="~/Shipper/Delete/@Model.ShipperID">
            @if (ViewBag.CanDelete)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    Bạn có chắc chắn muốn xóa người giao hàng này không?
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <i class="bi bi-info-circle me-2"></i>
                    Không thể xóa vì người giao hàng này đã có dữ liệu liên quan!
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Tên người giao hàng</dt>
                <dd class="col-sm-9">@Model.ShipperName</dd>

                <dt class="col-sm-3">Điện thoại</dt>
                <dd class="col-sm-9">@Model.Phone</dd>
            </dl>
        </form>
    </div>
</div>