@model OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-success">
    <strong class="modal-title">Hoàn tất đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    <div class="alert alert-success">
        <i class="bi bi-info-circle me-2"></i>
        Xác nhận đơn hàng <strong>#@Model.OrderID</strong> đã giao thành công?
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-success"
            onclick="processOrder('@Url.Action("Finish", "Order", new { id = Model.OrderID })')">
        <i class="bi bi-check"></i> Xác nhận
    </button>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        Đóng
    </button>
</div>