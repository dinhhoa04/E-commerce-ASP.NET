@model ProductSearchInput
@using SV22T1020123.BusinessLayers
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>
            <div class="card-body p-2">
                <form id="formSearchProduct"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="productList"
                      onsubmit="paginationSearch(event, this, 1)">
                    <input type="hidden" asp-for="PageSize" />
                    <div class="input-group mb-2">
                        <input type="text" asp-for="SearchValue"
                               class="form-control"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
                <div id="productList"></div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <div id="shoppingCart">
            @await Html.PartialAsync("ShowCart",
                     SV22T1020123.Admin.ShoppingCartService.GetShoppingCart())
        </div>

        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="card card-outline card-info mt-3">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-person"></i>
                    Thông tin khách hàng & nơi giao hàng
                </h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <label class="col-md-2 col-form-label">Khách hàng</label>
                    <div class="col-md-10">
                        @{
                            var searchInput = new SV22T1020123.Models.Common.PaginationSearchInput { Page = 1, PageSize = 1000, SearchValue = "" };
                            // Chỉ cần gọi trực tiếp PartnerDataService, không cần đường dẫn dài nữa
                            var customers = await PartnerDataService.ListCustomersAsync(searchInput);
                        }
                        <select id="customerID" class="form-select">
                            <option value="0">-- Chọn khách hàng --</option>
                            @if (customers != null)
                            {
                                foreach (var c in customers.DataItems)
                                {
                                            <option value="@c.CustomerID">@c.CustomerName (@c.Phone)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                    <div class="col-md-10">
                        <select id="province" class="form-select"
                                asp-items="await SelectListHelper.Provinces()">
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <label class="col-md-2 col-form-label">Địa chỉ</label>
                    <div class="col-md-10">
                        <textarea id="address" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="text-end">
                    <button class="btn btn-primary" onclick="createOrder()">
                        <i class="bi bi-check-circle"></i>
                        Lập đơn hàng
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearchProduct"), parseInt('@Model.Page'));
        });

        function createOrder() {
            const customerID = document.getElementById("customerID").value;
            const province = document.getElementById("province").value;
            const address = document.getElementById("address").value;

            fetch(`/Order/CreateOrder`, {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: `customerID=${customerID}&province=${province}&address=${address}`
            })
                .then(r => r.json())
                .then(result => {
                    if (result.code <= 0) {
                        alert(result.message);
                    } else {
                        window.location.href = `/Order/Detail/${result.code}`;
                    }
                });
        }

        
    
        // Hàm load lại giỏ hàng của bạn (giữ nguyên)
        function reloadCart() {
            fetch("/Order/ShowCart")
                .then(r => r.text())
                .then(html => {
                    document.getElementById("shoppingCart").innerHTML = html;
                });
        }

        // --- CÁC HÀM XỬ LÝ MODAL (MỚI THÊM) ---

        // 1. Hàm cập nhật mặt hàng trong giỏ
        function updateCartItem(productId) {
            // Lấy giá trị chuỗi trong ô nhập giá (VD: "323.000")
            let priceString = document.getElementById("editPrice").value;
            // Xóa tất cả dấu chấm (phân cách hàng nghìn) và chuyển thành số
            const price = parseFloat(priceString.replace(/\./g, '').replace(/,/g, ''));

            const quantity = parseInt(document.getElementById("editQty").value);

            fetch("/Order/UpdateCartItem", {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: `productId=${productId}&quantity=${quantity}&salePrice=${price}`
            })
                .then(r => r.json())
                .then(result => {
                    if (result.code <= 0) {
                        alert(result.message);
                    } else {
                        bootstrap.Modal.getInstance(document.getElementById("dialogModal")).hide();
                        reloadCart(); // Gọi lại giỏ hàng
                    }
                })
                .catch(error => {
                    console.error("Lỗi cập nhật giỏ hàng:", error);
                    alert("Đã xảy ra lỗi khi cập nhật!");
                });
        }

        // 2. Hàm xóa 1 mặt hàng khỏi giỏ
        function deleteCartItem(productId) {
            fetch(`/Order/DeleteCartItem?productId=${productId}`, {
                method: "POST"
            })
            .then(r => r.json())
            .then(result => {
                if (result.code > 0) {
                    bootstrap.Modal.getInstance(document.getElementById("dialogModal")).hide();
                    reloadCart(); // Gọi lại giỏ hàng
                }
            });
        }

        // 3. Hàm xóa toàn bộ giỏ hàng
        function clearCart() {
            fetch("/Order/ClearCart", { method: "POST" })
            .then(r => r.json())
            .then(result => {
                if (result.code > 0) {
                    bootstrap.Modal.getInstance(document.getElementById("dialogModal")).hide();
                    reloadCart(); // Gọi lại giỏ hàng
                }
            });
        }
 



        function addToCart(productID) {
            const priceInput = document.getElementById("price_" + productID);
            const qtyInput = document.getElementById("qty_" + productID);

            // Lấy giá trị, xóa hết dấu chấm (.) và phẩy (,) phân cách hàng nghìn
            const price = priceInput.value.replace(/\./g, '').replace(/,/g, '');
            const quantity = parseInt(qtyInput.value);

            fetch("/Order/AddCartItem", {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: `productID=${productID}&quantity=${quantity}&price=${price}`
            })
                .then(r => r.json())
                .then(result => {
                    if (result.code <= 0) {
                        alert(result.message);
                    } else {
                        reloadCart(); // Thành công thì load lại giỏ hàng
                    }
                });
        }
    
    </script>
}