@{
    ViewBag.Title = "Xóa đơn hàng";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card card-outline card-danger">

            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Xác nhận xóa đơn hàng
                </h5>
            </div>

            <div class="card-body">

                <div class="alert alert-warning">
                    Bạn có chắc chắn muốn <strong>xóa</strong> đơn hàng này không?
                </div>

                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Mã đơn hàng:</div>
                    <div class="col-md-8">#1001</div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Khách đặt hàng:</div>
                    <div class="col-md-8">Nguyễn Văn A</div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Thời điểm tạo:</div>
                    <div class="col-md-8">10/02/2026 09:15</div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Địa chỉ giao hàng:</div>
                    <div class="col-md-8">123 Lê Lợi, Quận 1</div>
                </div>

            </div>

            <div class="card-footer d-flex justify-content-end">
                <a href="/Order" class="btn btn-secondary me-2">
                    Bỏ qua
                </a>
                <button class="btn btn-danger">
                    <i class="bi bi-trash"></i> Xóa đơn hàng
                </button>
            </div>

        </div>
    </div>
</div>
