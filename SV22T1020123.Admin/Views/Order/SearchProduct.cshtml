@model PagedResult<Product>
@{
    Layout = null;
}

@foreach (var item in Model.DataItems)
{
    <div class="border rounded p-2 mb-2">
        <strong>@item.ProductName</strong>
        <div class="row mt-1">
            <div class="col-4">
                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                     class="img-fluid border" style="max-height:80px" />
            </div>
            <div class="col-8">
                <div class="row g-1">
                    <div class="col-7">
                        <label class="form-label mb-0 small">Giá</label>
                        <input class="form-control form-control-sm money-input"
                               id="price_@item.ProductID"
                               value="@((long)item.Price)" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0 small">SL</label>
                        <input type="number" min="1" value="1"
                               id="qty_@item.ProductID"
                               class="form-control form-control-sm" />
                    </div>
                </div>
                <button class="btn btn-sm btn-primary mt-1 w-100"
                        onclick="addToCart(@item.ProductID)">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </div>
}

<ul class="pagination justify-content-between mb-0 mt-2">
    @if (Model.Page > 1)
    {
        <li class="page-item">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearchProduct'), @(Model.Page - 1))">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>
    }
    <li class="page-item disabled">
        <span class="page-link">@Model.Page / @Model.PageCount</span>
    </li>
    @if (Model.Page < Model.PageCount)
    {
        <li class="page-item">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearchProduct'), @(Model.Page + 1))">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    }
</ul>

