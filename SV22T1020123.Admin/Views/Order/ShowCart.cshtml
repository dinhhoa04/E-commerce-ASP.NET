@model List<OrderDetailViewInfo>
@{
    Layout = null;
    decimal total = Model.Sum(x => x.TotalPrice);
}

<div class="card card-outline card-success">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi bi-cart"></i>
            Danh sách mặt hàng đã chọn
        </h5>
    </div>
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-success">
                <tr>
                    <th class="text-center">#</th>
                    <th>Tên hàng</th>
                    <th class="text-center">ĐVT</th>
                    <th class="text-center">SL</th>
                    <th class="text-end">Giá</th>
                    <th class="text-end">Thành tiền</th>
                    <th style="width:80px"></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var item = Model[i];
                    <tr>
                        <td class="text-center">@(i + 1)</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                        <td class="text-center text-nowrap">
                            <a class="btn btn-sm btn-primary open-modal"
                               href="~/Order/EditCartItem?productId=@item.ProductID">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-danger open-modal"
                               href="~/Order/DeleteCartItem?productId=@item.ProductID">
                                <i class="bi bi-dash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng:</th>
                    <th class="text-end">@total.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <div class="card-footer text-end">
            <a class="btn btn-sm btn-danger open-modal" href="~/Order/ClearCart">
                <i class="bi bi-trash"></i>
                Xóa giỏ hàng
            </a>
        </div>
    }
</div>