@model OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">Xóa mặt hàng khỏi đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    <div class="alert alert-danger">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có muốn xóa mặt hàng <strong>@Model.ProductName</strong> ra khỏi đơn hàng không?
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-danger"
            onclick="deleteCartItem(@Model.ProductID)">
        <i class="bi bi-check"></i> Xác nhận
    </button>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        Đóng
    </button>
</div>

<script>
    function deleteCartItem(productId) {
        fetch(`/Order/DeleteCartItem?productId=${productId}`, {
            method: "POST"
        })
        .then(r => r.json())
        .then(result => {
            if (result.code > 0) {
                bootstrap.Modal.getInstance(document.getElementById("dialogModal")).hide();
                reloadCart();
            }
        });
    }
</script>