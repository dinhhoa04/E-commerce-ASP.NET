@model OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">Từ chối đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    <div class="alert alert-danger">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có chắc chắn muốn từ chối đơn hàng <strong>#@Model.OrderID</strong> không?
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-danger"
            onclick="processOrder('@Url.Action("Reject", "Order", new { id = Model.OrderID })')">
        <i class="bi bi-check"></i> Xác nhận
    </button>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        Đóng
    </button>
</div>