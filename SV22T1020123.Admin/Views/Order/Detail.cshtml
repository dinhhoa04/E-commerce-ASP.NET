@model OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var details = ViewBag.Details as List<OrderDetailViewInfo>
                  ?? new List<OrderDetailViewInfo>();
    decimal total = details.Sum(d => d.TotalPrice);
}

@section PageToolBar {
    @if (Model.Status == OrderStatusEnum.New)
    {
        <a class="btn btn-info ms-1 open-modal" href="~/Order/Accept/@Model.OrderID">
            <i class="bi bi-check-circle me-1"></i>Duyệt đơn
        </a>
        <a class="btn btn-warning ms-1 open-modal" href="~/Order/Reject/@Model.OrderID">
            <i class="bi bi-x-circle me-1"></i>Từ chối
        </a>
        <a class="btn btn-secondary ms-1 open-modal" href="~/Order/Cancel/@Model.OrderID">
            <i class="bi bi-slash-circle me-1"></i>Hủy đơn
        </a>
    }
    @if (Model.Status == OrderStatusEnum.Accepted)
    {
        <a class="btn btn-primary ms-1 open-modal" href="~/Order/Shipping/@Model.OrderID">
            <i class="bi bi-truck me-1"></i>Giao hàng
        </a>
        <a class="btn btn-secondary ms-1 open-modal" href="~/Order/Cancel/@Model.OrderID">
            <i class="bi bi-slash-circle me-1"></i>Hủy đơn
        </a>
    }
    @if (Model.Status == OrderStatusEnum.Shipping)
    {
        <a class="btn btn-success ms-1 open-modal" href="~/Order/Finish/@Model.OrderID">
            <i class="bi bi-check2-all me-1"></i>Hoàn tất
        </a>
    }
    @if (Model.Status == OrderStatusEnum.New)
    {
        <a class="btn btn-danger ms-1 open-modal" href="~/Order/Delete/@Model.OrderID">
            <i class="bi bi-trash me-1"></i>Xóa
        </a>
    }
    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>Quay lại
    </a>
}

@{
    var (alertClass, alertIcon, statusText) = Model.Status switch
    {
        OrderStatusEnum.New => ("alert-warning", "bi-clock",
            "Đơn hàng mới, chờ duyệt"),
        OrderStatusEnum.Accepted => ("alert-info", "bi-check-circle",
            $"Đã duyệt lúc {Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm")}"),
        OrderStatusEnum.Shipping => ("alert-primary", "bi-truck",
            $"Đang giao hàng từ {Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm")}"),
        OrderStatusEnum.Completed => ("alert-success", "bi-check2-all",
            $"Hoàn tất lúc {Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")}"),
        OrderStatusEnum.Rejected => ("alert-danger", "bi-x-circle",
            $"Bị từ chối lúc {Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")}"),
        OrderStatusEnum.Cancelled => ("alert-secondary", "bi-slash-circle",
            $"Đã hủy lúc {Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")}"),
        _ => ("alert-light", "bi-question", "Không xác định")
    };
}

<div class="alert @alertClass d-flex align-items-center mb-3">
    <i class="bi @alertIcon fs-4 me-2"></i>
    <div><strong>Trạng thái:</strong> @statusText</div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>Thông tin đơn hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.EmployeeName</div>
            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">
                @(Model.AcceptTime.HasValue
                    ? Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm")
                    : "")
            </div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>Thông tin khách hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>
            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>Thông tin giao hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.ShipperName</div>
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>Danh sách mặt hàng
        </h5>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th class="text-end">Giá</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < details.Count; i++)
                {
                    var d = details[i];
                    <tr>
                        <td class="text-center">@(i + 1)</td>
                        <td>@d.ProductName</td>
                        <td class="text-center">@d.Unit</td>
                        <td class="text-center">@d.Quantity</td>
                        <td class="text-end">@d.SalePrice.ToString("N0")</td>
                        <td class="text-end">@d.TotalPrice.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@total.ToString("N0")</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}

@section Scripts {
    <script>
        function reloadPage() {
            window.location.reload();
        }
    </script>
}