@model Supplier
@{
    ViewBag.Title = "Xóa nhà cung cấp";
}
@section PageToolBar {
    @if (ViewBag.CanDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0 text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @(ViewBag.CanDelete ? "Xác nhận xóa nhà cung cấp" : "Thông báo")
        </h5>
    </div>
    <div class="card-body">
        <form id="formDelete" method="post"
              action="~/Supplier/Delete/@Model.SupplierID">
            @if (ViewBag.CanDelete)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    Bạn có chắc chắn muốn xóa nhà cung cấp này không?
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <i class="bi bi-info-circle me-2"></i>
                    Không thể xóa vì nhà cung cấp này đã có dữ liệu liên quan!
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Tên nhà cung cấp</dt>
                <dd class="col-sm-9">@Model.SupplierName</dd>

                <dt class="col-sm-3">Tên giao dịch</dt>
                <dd class="col-sm-9">@Model.ContactName</dd>

                <dt class="col-sm-3">Điện thoại</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Địa chỉ</dt>
                <dd class="col-sm-9">@Model.Address</dd>

                <dt class="col-sm-3">Tỉnh / Thành</dt>
                <dd class="col-sm-9">@Model.Province</dd>
            </dl>
        </form>
    </div>
</div>