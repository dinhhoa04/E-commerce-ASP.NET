@model Category
@{
    ViewBag.Title = "Xóa loại hàng";
}
@section PageToolBar {
    @if (ViewBag.CanDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0 text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @(ViewBag.CanDelete ? "Xác nhận xóa loại hàng" : "Thông báo")
        </h5>
    </div>
    <div class="card-body">
        <form id="formDelete" method="post"
              action="~/Category/Delete/@Model.CategoryID">
            @if (ViewBag.CanDelete)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    Bạn có chắc chắn muốn xóa loại hàng này không?
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <i class="bi bi-info-circle me-2"></i>
                    Không thể xóa vì loại hàng này đang có mặt hàng liên quan!
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Tên loại hàng</dt>
                <dd class="col-sm-9">@Model.CategoryName</dd>

                <dt class="col-sm-3">Mô tả</dt>
                <dd class="col-sm-9">@Model.Description</dd>
            </dl>
        </form>
    </div>
</div>