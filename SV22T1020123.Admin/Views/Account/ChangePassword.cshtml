@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card card-primary card-outline shadow">
            <div class="card-header">
                <h5 class="card-title m-0 fw-bold"><i class="bi bi-shield-lock me-2 text-primary"></i>Thay đổi mật khẩu</h5>
            </div>

            <div class="card-body">
                @Html.ValidationMessage("Error", new { @class = "text-danger mb-3 d-block fw-bold" })

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success fw-bold">
                        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                    </div>
                }

                <form action="~/Account/ChangePassword" method="post">
                    <div class="form-group mb-3">
                        <label class="fw-bold mb-1">Mật khẩu cũ <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                            <input type="password" class="form-control" name="oldPassword" required autofocus />
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="fw-bold mb-1">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="password" class="form-control" name="newPassword" required minlength="3" />
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="fw-bold mb-1">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-check-circle"></i></span>
                            <input type="password" class="form-control" name="confirmPassword" required minlength="3" />
                        </div>
                    </div>

                    <div class="form-group text-end">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-1"></i> Đổi mật khẩu
                        </button>
                        <a href="~/Home" class="btn btn-secondary ms-2">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>