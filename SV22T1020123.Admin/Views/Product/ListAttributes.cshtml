@model List<ProductAttribute>
@{
    Layout = null;
    int productID = ViewContext.RouteData.Values["id"] != null
        ? Convert.ToInt32(ViewContext.RouteData.Values["id"])
        : (Model.Count > 0 ? Model[0].ProductID : 0);
}

<div class="card card-success card-outline mt-4">
    <div class="card-header">
        <div class="row">
            <div class="col">
                <h6 id="attributes" class="card-title mb-0">
                    <i class="bi bi-list-check me-2"></i>
                    Thuộc tính mặt hàng
                </h6>
            </div>
            <div class="col text-end">
                <a class="btn btn-sm btn-primary"
                   href="~/Product/EditAttributes/@productID">
                    <i class="bi bi-plus"></i>
                    Thêm thuộc tính
                </a>
            </div>
        </div>
    </div>
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên thuộc tính</th>
                    <th>Giá trị</th>
                    <th style="width:100px" class="text-center">Thứ tự</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.AttributeName</td>
                        <td>@item.AttributeValue</td>
                        <td class="text-center">@item.DisplayOrder</td>
                        <td class="text-center text-nowrap">
                            <a class="btn btn-sm btn-primary"
                               href="~/Product/EditAttributes/@item.ProductID?attributeID=@item.AttributeID">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-danger"
                               href="~/Product/DeleteAttributes/@item.ProductID?attributeID=@item.AttributeID">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>