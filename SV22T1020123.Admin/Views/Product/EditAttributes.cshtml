@model ProductAttribute
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>
            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SaveAttribute">
                    <input type="hidden" asp-for="AttributeID" />
                    <input type="hidden" asp-for="ProductID" />

                    <div class="mb-3">
                        <label class="form-label">Tên thuộc tính</label>
                        <input type="text" asp-for="AttributeName"
                               class="form-control"
                               placeholder="Ví dụ: Màu sắc, Kích thước" autofocus />
                        <span asp-validation-for="AttributeName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Giá trị thuộc tính</label>
                        <input type="text" asp-for="AttributeValue"
                               class="form-control"
                               placeholder="Ví dụ: Đỏ, XL, 500g" />
                        <span asp-validation-for="AttributeValue" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input type="number" asp-for="DisplayOrder"
                               class="form-control"
                               style="width:100px;" min="1" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>