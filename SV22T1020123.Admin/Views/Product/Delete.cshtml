@model Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}
@section PageToolBar {
    @if (ViewBag.CanDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0 text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @(ViewBag.CanDelete ? "Xác nhận xóa mặt hàng" : "Thông báo")
        </h5>
    </div>
    <div class="card-body">
        <form id="formDelete" method="post"
              action="~/Product/Delete/@Model.ProductID">
            @if (ViewBag.CanDelete)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    Bạn có chắc chắn muốn xóa mặt hàng này không?
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <i class="bi bi-info-circle me-2"></i>
                    Không thể xóa vì mặt hàng này đã có dữ liệu liên quan!
                </div>
            }

            <div class="row">
                <div class="col-md-3 text-center">
                    <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-thumbnail"
                         style="max-height:200px;" />
                </div>
                <div class="col-md-9">
                    <dl class="row">
                        <dt class="col-sm-4">Tên mặt hàng</dt>
                        <dd class="col-sm-8">@Model.ProductName</dd>

                        <dt class="col-sm-4">Đơn vị tính</dt>
                        <dd class="col-sm-8">@Model.Unit</dd>

                        <dt class="col-sm-4">Giá bán</dt>
                        <dd class="col-sm-8">@Model.Price.ToString("N0") đ</dd>

                        <dt class="col-sm-4">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng bán</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Mô tả</dt>
                        <dd class="col-sm-8">@Model.ProductDescription</dd>
                    </dl>
                </div>
            </div>
        </form>
    </div>
</div>