@model ProductPhoto
@{
    ViewBag.Title = "Xóa ảnh";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i>
        Xóa
    </button>
    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0 text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Xác nhận xóa ảnh
        </h5>
    </div>
    <div class="card-body">
        <form id="formDelete" method="post"
              action="~/Product/DeletePhotos/@Model.ProductID?photoID=@Model.PhotoID">
            <div class="alert alert-warning">
                <i class="bi bi-info-circle me-2"></i>
                Bạn có chắc chắn muốn xóa ảnh này không?
            </div>
            <div class="text-center mb-3">
                <img src="~/images/products/@Model.Photo"
                     class="img-thumbnail"
                     style="max-height:200px;" />
            </div>
            <dl class="row">
                <dt class="col-sm-3">Mô tả</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Thứ tự</dt>
                <dd class="col-sm-9">@Model.DisplayOrder</dd>

                <dt class="col-sm-3">Hiển thị</dt>
                <dd class="col-sm-9">
                    @if (Model.IsHidden)
                    {
                        <span class="badge bg-secondary">Ẩn</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Hiện</span>
                    }
                </dd>
            </dl>
        </form>
    </div>
</div>