@{
    ViewBag.Title = "Xóa thuộc tính";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card card-outline card-danger">
            <div class="card-header">
                <h5 class="card-title mb-0">Xóa thuộc tính</h5>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    Bạn có chắc chắn muốn xóa thuộc tính này không?
                </div>

                <p><strong>Tên:</strong> Màu sắc</p>
                <p><strong>Giá trị:</strong> Đen</p>
            </div>

            <div class="card-footer d-flex justify-content-end">
                <button class="btn btn-secondary me-2">Bỏ qua</button>
                <button class="btn btn-danger">Xóa</button>
            </div>
        </div>
    </div>
</div>
