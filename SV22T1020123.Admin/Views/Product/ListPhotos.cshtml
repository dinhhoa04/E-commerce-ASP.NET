@model List<ProductPhoto>
@{
    Layout = null;
    int productID = ViewContext.RouteData.Values["id"] != null
        ? Convert.ToInt32(ViewContext.RouteData.Values["id"])
        : (Model.Count > 0 ? Model[0].ProductID : 0);
}

<div class="card card-info card-outline mt-4">
    <div class="card-header">
        <div class="row">
            <div class="col">
                <h6 id="photos" class="mb-0">
                    <i class="bi bi-images me-2"></i>
                    Thư viện ảnh
                </h6>
            </div>
            <div class="col text-end">
                <a class="btn btn-sm btn-primary"
                   href="~/Product/EditPhotos/@productID">
                    <i class="bi bi-plus-circle me-1"></i>
                    Thêm ảnh
                </a>
            </div>
        </div>
    </div>
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:120px">Ảnh</th>
                    <th>Mô tả</th>
                    <th style="width:100px" class="text-center">Thứ tự</th>
                    <th style="width:100px" class="text-center">Hiển thị</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">
                            <img src="~/images/products/@item.Photo"
                                 class="img-thumbnail"
                                 style="max-height:80px;" />
                        </td>
                        <td>@item.Description</td>
                        <td class="text-center">@item.DisplayOrder</td>
                        <td class="text-center">
                            @if (item.IsHidden)
                            {
                                <span class="badge bg-secondary">Ẩn</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hiện</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a class="btn btn-sm btn-primary"
                               href="~/Product/EditPhotos/@item.ProductID?photoID=@item.PhotoID">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-danger"
                               href="~/Product/DeletePhotos/@item.ProductID?photoID=@item.PhotoID">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>