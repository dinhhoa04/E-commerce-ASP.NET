@using SV22T1020123.Models.Sales
@model IList<OrderViewInfo>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="row mt-4">
    <div class="col-md-3 mb-4">
        <div class="list-group shadow-sm">
            <a href="~/Account/Profile" class="list-group-item list-group-item-action">
                <i class="bi bi-person-vcard me-2"></i> Hồ sơ cá nhân
            </a>
            <a href="~/Order/History" class="list-group-item list-group-item-action active fw-bold">
                <i class="bi bi-receipt me-2"></i> Lịch sử đơn hàng
            </a>
            <a href="~/Account/ChangePassword" class="list-group-item list-group-item-action">
                <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
            </a>
            <a href="~/Account/Logout" class="list-group-item list-group-item-action text-danger">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-bold fs-5 py-3">
                Lịch sử đơn hàng của bạn
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Giao đến (Tỉnh/Thành)</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 fw-semibold">#@item.OrderID</td>
                                        <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@item.DeliveryProvince</td>
                                        <td class="text-center">
                                            @if (item.Status == OrderStatusEnum.New)
                                            {
                                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                            }
                                            else if (item.Status == OrderStatusEnum.Accepted)
                                            {
                                                <span class="badge bg-info">Đã duyệt</span>
                                            }
                                            else if (item.Status == OrderStatusEnum.Shipping)
                                            {
                                                <span class="badge bg-primary">Đang giao</span>
                                            }
                                            else if (item.Status == OrderStatusEnum.Completed)
                                            {
                                                <span class="badge bg-success">Hoàn tất</span>
                                            }
                                            else if (item.Status == OrderStatusEnum.Rejected)
                                            {
                                                <span class="badge bg-danger">Bị từ chối</span>
                                            }
                                            else if (item.Status == OrderStatusEnum.Cancelled)
                                            {
                                                <span class="badge bg-secondary">Đã hủy</span>
                                            }
                                        </td>
                                        <td class="text-center pe-4">
                                            <a href="~/Order/Details/@item.OrderID" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">Bạn chưa có đơn hàng nào. Mua sắm ngay!</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>