@model SV22T1020123.Models.Partner.Customer
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="row justify-content-center py-5">
    <div class="col-md-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white text-center py-3">
                <h4 class="fw-bold mb-0">Tạo tài khoản mới</h4>
            </div>
            <div class="card-body p-4">
                @Html.ValidationMessage("Error", new { @class = "text-danger mb-3 d-block" })

                <form action="~/Account/Register" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" asp-for="CustomerName" class="form-control" required autofocus />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="tel" asp-for="Phone" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <input type="email" asp-for="Email" class="form-control" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" name="password" class="form-control" required minlength="6" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tỉnh/Thành phố</label>
                        <select class="form-select" asp-for="Province" asp-items="ViewBag.Provinces">
                            <option value="">-- Chọn Tỉnh/Thành phố --</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Địa chỉ chi tiết</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-3">Đăng ký ngay</button>

                    <div class="text-center">
                        <p class="mb-1">Đã có tài khoản? <a href="~/Account/Login" class="text-decoration-none">Đăng nhập</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>