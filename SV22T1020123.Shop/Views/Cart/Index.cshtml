@using SV22T1020123.Models.Sales
@model List<OrderDetailViewInfo>
@{
    ViewData["Title"] = "Giỏ hàng";
    decimal totalAmount = Model.Sum(x => x.TotalPrice);
}

<div class="d-flex align-items-center gap-3 mb-4">
    <h3 class="fw-bold mb-0">
        <i class="bi bi-cart3 me-2 text-primary"></i>Giỏ hàng
    </h3>
    <span class="badge bg-primary rounded-pill">@Model.Count sản phẩm</span>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="card border-0 shadow-sm rounded-4 text-center py-5">
        <div class="card-body">
            <i class="bi bi-cart-x fs-1 text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Giỏ hàng đang trống</h5>
            <p class="text-muted small">Hãy thêm sản phẩm vào giỏ hàng của bạn</p>
            <a href="~/" class="btn btn-primary rounded-pill px-4 mt-2">
                <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <!-- DANH SÁCH SẢN PHẨM -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:80px;" class="ps-3">Ảnh</th>
                            <th>Sản phẩm</th>
                            <th class="text-center" style="width:130px;">Số lượng</th>
                            <th class="text-end pe-3">Thành tiền</th>
                            <th style="width:50px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <img src="/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="rounded-3"
                                         style="width:60px;height:60px;object-fit:contain;background:#f8fafc;" />
                                </td>
                                <td>
                                    <a href="~/Home/Detail/@item.ProductID"
                                       class="fw-semibold text-dark text-decoration-none">
                                        @item.ProductName
                                    </a>
                                    <div class="text-muted small mt-1">
                                        @item.SalePrice.ToString("N0") đ / @item.Unit
                                    </div>
                                </td>
                                <td>
                                    <form action="~/Cart/UpdateCart" method="post">
                                        <input type="hidden" name="id" value="@item.ProductID" />
                                        <div class="input-group input-group-sm justify-content-center">
                                            <input type="number" name="quantity"
                                                   class="form-control text-center"
                                                   style="max-width:70px;"
                                                   value="@item.Quantity" min="1"
                                                   onchange="this.form.submit()" />
                                        </div>
                                    </form>
                                </td>
                                <td class="text-end pe-3 fw-bold text-danger">
                                    @item.TotalPrice.ToString("N0") đ
                                </td>
                                <td class="text-center">
                                    <a href="~/Cart/RemoveFromCart/@item.ProductID"
                                       class="btn btn-sm btn-outline-danger rounded-circle"
                                       title="Xóa"
                                       onclick="return confirm('Xóa sản phẩm này?')">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4 mb-4">
                <a href="~/" class="btn btn-outline-primary rounded-pill">
                    <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sắm
                </a>

                <a href="~/Cart/ClearCart" class="btn btn-outline-danger rounded-pill"
                   onclick="return confirm('Bạn có chắc chắn muốn xóa toàn bộ sản phẩm trong giỏ hàng không?');">
                    <i class="bi bi-trash me-1"></i> Xóa giỏ hàng
                </a>
            </div>


        </div>

        <!-- TÓM TẮT ĐƠN HÀNG -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 border-0 py-3">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-receipt me-2"></i>Tóm tắt đơn hàng
                    </h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Tạm tính (@Model.Count SP)</span>
                        <span class="fw-semibold">@totalAmount.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Phí giao hàng</span>
                        <span class="text-success fw-semibold">Miễn phí</span>
                    </div>
                    <div class="d-flex justify-content-between py-3">
                        <span class="fs-5 fw-bold">Tổng cộng</span>
                        <span class="fs-5 fw-bold text-danger">
                            @totalAmount.ToString("N0") đ
                        </span>
                    </div>

                    <a href="~/Order/Checkout"
                       class="btn btn-primary w-100 rounded-pill py-2 fw-bold">
                        Đặt hàng ngay <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <p class="text-muted text-center small mt-3 mb-0">
                        <i class="bi bi-shield-lock me-1"></i>
                        Thanh toán an toàn & bảo mật
                    </p>
                </div>
            </div>
        </div>
    </div>
}