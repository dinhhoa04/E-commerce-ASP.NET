@using SV22T1020123.Models.Sales
@model List<OrderDetailViewInfo>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    decimal totalAmount = Model.Sum(x => x.TotalPrice);
}

<h3 class="mb-4 fw-bold">Giỏ hàng của bạn</h3>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-cart-x fs-1 text-muted d-block mb-3"></i>
        <h5>Giỏ hàng đang trống</h5>
        <a href="~/" class="btn btn-primary mt-3">Tiếp tục mua sắm</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 100px;">Ảnh</th>
                                <th>Sản phẩm</th>
                                <th class="text-center" style="width: 150px;">Số lượng</th>
                                <th class="text-end">Tạm tính</th>
                                <th class="text-center" style="width: 60px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="http://localhost:5284/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" class="img-thumbnail" style="height: 60px; width: 60px; object-fit: contain;" />
                                    </td>
                                    <td>
                                        <a href="~/Home/Detail/@item.ProductID" class="text-decoration-none fw-semibold text-dark">@item.ProductName</a>
                                        <div class="text-muted small">@item.SalePrice.ToString("N0") đ</div>
                                    </td>
                                    <td>
                                        <form action="~/Cart/UpdateCart" method="post" class="d-flex">
                                            <input type="hidden" name="id" value="@item.ProductID" />
                                            <input type="number" name="quantity" class="form-control form-control-sm text-center" value="@item.Quantity" min="1" onchange="this.form.submit()">
                                        </form>
                                    </td>
                                    <td class="text-end text-danger fw-bold">
                                        @item.TotalPrice.ToString("N0") đ
                                    </td>
                                    <td class="text-center">
                                        <a href="~/Cart/RemoveFromCart/@item.ProductID" class="text-danger" title="Xóa">
                                            <i class="bi bi-trash3 fs-5"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4 mt-4 mt-md-0">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tổng phụ:</span>
                        <span class="fw-bold">@totalAmount.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí giao hàng:</span>
                        <span>Đang tính</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fs-5 fw-bold">Tổng cộng:</span>
                        <span class="fs-5 text-danger fw-bold">@totalAmount.ToString("N0") đ</span>
                    </div>

                    <a href="~/Order/Checkout" class="btn btn-primary w-100 py-2 fs-5">
                        Tiến hành đặt hàng <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
}