<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TNP Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --accent: #f97316;
        }
        body { background: #f8fafc; font-family: 'Segoe UI', sans-serif; }

        /* NAVBAR */
        .navbar-main {
            background: linear-gradient(135deg, #1e40af, #2563eb);
            box-shadow: 0 2px 12px rgba(37,99,235,0.15);
            padding: 0.75rem 0;
        }
        .navbar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .navbar-brand span { color: #fbbf24; }
        .nav-link { color: rgba(255,255,255,0.85) !important; font-weight: 500; }
        .nav-link:hover { color: #fff !important; }
        .cart-btn {
            position: relative;
            background: rgba(255,255,255,0.15);
            border-radius: 50px;
            padding: 6px 16px;
            color: #fff !important;
            transition: all 0.2s;
        }
        .cart-btn:hover { background: rgba(255,255,255,0.25); }
        .cart-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            background: #ef4444;
            color: #fff;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            font-size: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }

        /* FOOTER */
        .footer-main {
            background: #1e293b;
            color: #94a3b8;
            padding: 2rem 0 1rem;
            margin-top: 4rem;
        }
        .footer-main a { color: #60a5fa; text-decoration: none; }
        .footer-main a:hover { color: #93c5fd; }
        .footer-bottom {
            border-top: 1px solid #334155;
            margin-top: 1.5rem;
            padding-top: 1rem;
            font-size: 0.85rem;
        }

        /* TOAST */
        .toast-container { z-index: 9999; }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-main">
        <div class="container">
            <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
                <i class="bi bi-bag-heart-fill me-2"></i>TNP<span>Shop</span>
            </a>
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto ms-3">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Sản phẩm
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center gap-2">
                    <!-- GIỎ HÀNG -->
                    <li class="nav-item">
                        <a class="nav-link cart-btn" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3 me-1"></i>Giỏ hàng
                            <span class="cart-badge" id="cart-badge">0</span>
                        </a>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                <li>
                                    <a class="dropdown-item" href="~/Account/Profile">
                                        <i class="bi bi-person me-2"></i>Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="~/Order/History">
                                        <i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="~/Account/Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm px-3" href="~/Account/Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning btn-sm px-3 fw-bold" href="~/Account/Register">
                                <i class="bi bi-person-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- NỘI DUNG -->
    <div class="container py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- TOAST THÔNG BÁO -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle me-2"></i>
                    <span id="toastMessage">Đã thêm vào giỏ hàng!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer-main">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="text-white fw-bold mb-3">
                        <i class="bi bi-bag-heart-fill me-2 text-warning"></i>TNPShop
                    </h5>
                    <p class="small">Cửa hàng công nghệ uy tín, chất lượng hàng đầu. Cam kết chính hãng, giao hàng nhanh toàn quốc.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-bold mb-3">Liên kết</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="~/"><i class="bi bi-chevron-right me-1"></i>Trang chủ</a></li>
                        <li class="mb-2"><a href="~/Cart/Index"><i class="bi bi-chevron-right me-1"></i>Giỏ hàng</a></li>
                        <li class="mb-2"><a href="~/Account/Login"><i class="bi bi-chevron-right me-1"></i>Đăng nhập</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-bold mb-3">Liên hệ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>Huế, Việt Nam</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2"></i>0901 234 567</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>contact@tnpshop.vn</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom text-center">
                &copy; 2026 TNPShop. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>