@using SV22T1020123.Models.Catalog
@using SV22T1020123.Models.Common
@model PagedResult<Product>
@{
    ViewData["Title"] = "Trang chủ";
    var searchInput = ViewBag.SearchInput as ProductSearchInput;
    var categories = ViewBag.Categories as PagedResult<Category>;
}

<div class="row g-4">
    <!-- BỘ LỌC -->
    <div class="col-lg-3">
        <form id="formSearch" action="~/" method="get">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-funnel me-2"></i>Bộ lọc sản phẩm</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">TÌM KIẾM</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" class="form-control border-start-0 ps-0"
                                   name="searchValue"
                                   value="@searchInput?.SearchValue"
                                   placeholder="Tên sản phẩm...">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">LOẠI HÀNG</label>
                        <select class="form-select" name="categoryId">
                            <option value="0">-- Tất cả --</option>
                            @if (categories != null)
                            {
                                foreach (var cat in categories.DataItems)
                                {
                                    @if (searchInput?.CategoryID == cat.CategoryID)
                                    {
                                        <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.CategoryID">@cat.CategoryName</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-muted">KHOẢNG GIÁ</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="number" class="form-control form-control-sm"
                                   name="minPrice"
                                   value="@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)"
                                   placeholder="Từ">
                            <span class="text-muted">—</span>
                            <input type="number" class="form-control form-control-sm"
                                   name="maxPrice"
                                   value="@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)"
                                   placeholder="Đến">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill">
                        <i class="bi bi-funnel me-1"></i>Lọc sản phẩm
                    </button>
                    <a href="~/" class="btn btn-outline-secondary w-100 rounded-pill mt-2">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Đặt lại
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- DANH SÁCH SẢN PHẨM -->
    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="text-muted mb-0">
                Tìm thấy <strong class="text-primary">@Model.RowCount</strong> sản phẩm
            </p>
        </div>

        @if (!Model.DataItems.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-search fs-1 text-muted"></i>
                <p class="text-muted mt-3">Không tìm thấy sản phẩm phù hợp</p>
                <a href="~/" class="btn btn-primary rounded-pill px-4">Xem tất cả</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
                @foreach (var item in Model.DataItems)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm product-card rounded-4">
                            <a href="~/Home/Detail/@item.ProductID" class="text-decoration-none">
                                <div class="product-img-wrap">
                                    <img src="http://localhost:5284/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="product-img"
                                         alt="@item.ProductName"
                                         onerror="this.src='http://localhost:5284/images/nophoto.png'" />
                                </div>
                            </a>
                            <div class="card-body d-flex flex-column p-3">
                                <a href="~/Home/Detail/@item.ProductID"
                                   class="text-decoration-none text-dark">
                                    <h6 class="product-title fw-semibold mb-2">@item.ProductName</h6>
                                </a>
                                <div class="mt-auto">
                                    <p class="text-danger fw-bold fs-5 mb-3">
                                        @item.Price.ToString("N0")<span class="fs-6">đ</span>
                                    </p>
                                    <button class="btn btn-primary w-100 rounded-pill btn-add-cart"
                                            data-id="@item.ProductID">
                                        <i class="bi bi-cart-plus me-1"></i>Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- PHÂN TRANG -->
            @if (Model.PageCount > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @foreach (var p in Model.GetDisplayPages())
                        {
                            if (p.IsCurrent)
                            {
                                <li class="page-item active">
                                    <span class="page-link rounded-pill">@p.Page</span>
                                </li>
                            }
                            else if (p.IsEllipsis)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link rounded-pill" href="~/?page=@p.Page&searchValue=@searchInput?.SearchValue&categoryId=@searchInput?.CategoryID&minPrice=@searchInput?.MinPrice&maxPrice=@searchInput?.MaxPrice">
                                        @p.Page
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

<style>
    .product-card { transition: all 0.25s ease; overflow: hidden; }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 12px 24px rgba(0,0,0,0.12) !important; }
    .product-img-wrap { height: 200px; display: flex; align-items: center; justify-content: center; padding: 1rem; background: #f8fafc; border-radius: 16px 16px 0 0; overflow: hidden; }
    .product-img { max-height: 100%; max-width: 100%; object-fit: contain; transition: transform 0.3s; }
    .product-card:hover .product-img { transform: scale(1.05); }
    .product-title { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; min-height: 2.8em; }
</style>